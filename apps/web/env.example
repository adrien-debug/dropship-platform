# =============================================================================
# Copy to .env.local (local) or paste into Vercel env settings.
# Marked [REQ] are required to boot. [OPT] degrade gracefully when absent.
# =============================================================================

# === Admin auth (Basic) [REQ] ===
# Without these, every /admin/* route 401s by design (fail-closed).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# === Postgres (Railway) [REQ] ===
# 23 migrations live in infra/postgres/. Apply once via `psql "$DATABASE_URL" -f infra/postgres/<NNN>_*.sql`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Optional read-replica routed for admin dashboards and storefront reads.
DATABASE_URL_REPLICA=

# === Medusa v2 backend [REQ] ===
MEDUSA_URL=https://your-medusa-backend.example.com
NEXT_PUBLIC_MEDUSA_URL=https://your-medusa-backend.example.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
MEDUSA_ADMIN_EMAIL=
MEDUSA_ADMIN_PASSWORD=

# === Anthropic Claude [REQ] ===
# Sonnet 4.6 powers every copilote. Haiku 4.5 still drives a few short calls
# (asset prompts, vision filter).
ANTHROPIC_API_KEY=

# === Kimi K2.5 (Moonshot AI via Hyper) [REQ for store creation] ===
# Replaces Claude Haiku 4.5 for product generation + enrichment in store-creator.
HYPER_API_KEY=
HYPER_API_BASE=https://api.hypercli.com/v1
KIMI_MODEL=kimi-k2.5

# === Suppliers [REQ for store creation] ===
# AliExpress DS API — OAuth token is stored in DB once the operator runs the
# flow at /api/aliexpress/oauth/start. Refreshed daily via GitHub Actions.
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
# CJ_DROPSHIPPING_API_KEY must be the API key generated under Account Settings
# → Developer, NOT the account password.
CJ_DROPSHIPPING_EMAIL=
CJ_DROPSHIPPING_API_KEY=

# === Stripe (storefront checkout) [REQ] ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# === Object storage — Cloudflare R2 [REQ for asset generation] ===
# Without R2 the asset generator falls back to writing under public/generated/
# (dev only; Vercel filesystem is read-only).
R2_ACCOUNT_ID=
R2_BUCKET=dropship-assets
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://pub-XXXX.r2.dev

# === Image / video generation [OPT but required for the medias copilote] ===
# fal.ai is the default backend (flux-pro/kontext for images, kling-video for promos).
FAL_KEY=
# ComfyUI Deploy override (replaces fal.ai when set). Multiple deployment IDs
# enable round-robin across GPUs.
COMFY_DEPLOY_API_KEY=
COMFYUI_URL=
COMFY_DEPLOYMENT_HERO=
COMFY_DEPLOYMENT_CUTOUT=
COMFY_DEPLOYMENT_LIFESTYLE=
COMFY_DEPLOYMENT_VIDEO=
COMFY_DEPLOYMENT_IDS=          # comma-separated, enables round-robin

# === Secrets encryption [REQ for analytics tokens] ===
# AES-256-GCM key (32 bytes base64). Encrypts Meta CAPI / TikTok Events / GA4
# secret tokens at rest in dropship_stores.
STORE_SECRETS_KEY=

# === Sentry [OPT] ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === Meta Marketing API [OPT — required to push ads to Meta] ===
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXX

# === TikTok Marketing API [OPT — required once TikTok approves the app] ===
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# === Google Ads API [OPT — required to push ads + Enhanced Conversions] ===
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=          # 10-digit, no dashes (the operating account)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # MCC parent; leave blank if OAuth has direct access
GOOGLE_ADS_CONVERSION_ACTION=    # e.g. customers/2877134493/conversionActions/7607691528
GOOGLE_MERCHANT_CENTER_ID=

# === Research providers (niche copilote) [OPT] ===
TAVILY_API_KEY=
PERPLEXITY_API_KEY=

# === SEO verification [OPT] ===
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# === Cross-platform helpers (configured but not yet wired in this app) [OPT] ===
OPENAI_API_KEY=                  # embeddings (future product similarity)
RESEND_API_KEY=                  # transactional email (anomaly alerts)
RESEND_FROM_EMAIL="Hearst Dropship <noreply@hearst.app>"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
AXIOM_TOKEN=
AXIOM_DATASET=
ARCJET_KEY=
