# =============================================================================
# Copier vers .env.local (local) ou coller dans Vercel / Railway (projet apps/web)
# =============================================================================

# --- Postgres (Railway ou autre) : table public.dropship_products requise
# Voir infra/postgres/001_dropship_products.sql à exécuter une fois sur cette base.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# --- Medusa (URL publique du backend)
MEDUSA_URL=https://ton-backend-medusa.example.com
# Option A — clé secrète (Medusa Admin → Settings → Secret API Keys) recommandé
MEDUSA_ADMIN_API_TOKEN=
# Option B — compte admin Medusa
MEDUSA_ADMIN_EMAIL=
MEDUSA_ADMIN_PASSWORD=

# Affichage URL Medusa dans l’UI admin (optionnel)
NEXT_PUBLIC_MEDUSA_URL=https://ton-backend-medusa.example.com

# --- Fournisseurs dropshipping (optionnel tant que l’import n’est pas utilisé)
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
CJ_DROPSHIPPING_EMAIL=
CJ_DROPSHIPPING_API_KEY=
