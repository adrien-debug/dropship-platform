# =============================================================================
# Copier vers .env.local (local) ou coller dans Vercel / Railway (apps/web)
# =============================================================================

# --- Supabase (projet cloud : https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Serveur uniquement (routes API) — ne jamais exposer au navigateur
SUPABASE_SERVICE_ROLE_KEY=

# --- Medusa (backend déployé p.ex. sur Railway)
# URL sans slash final
MEDUSA_URL=https://ton-backend.up.railway.app
# Option A — recommandé (Medusa v2 Admin → Settings → Secret API Keys)
MEDUSA_ADMIN_API_TOKEN=
# Option B — compte admin Medusa
MEDUSA_ADMIN_EMAIL=
MEDUSA_ADMIN_PASSWORD=
# Affichage dans l’UI admin (optionnel)
NEXT_PUBLIC_MEDUSA_URL=

# --- Fournisseurs (optionnel)
# ALIEXPRESS_APP_KEY=
# CJ_DROPSHIPPING_EMAIL=
# CJ_DROPSHIPPING_API_KEY=

# --- Stripe (si tu branches le paiement plus tard)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
