# =============================================================================
# Copy to .env.local (local) or paste into Vercel / Railway env settings.
# =============================================================================

# --- Admin auth (Basic) ---
# Set both before deploying — otherwise every admin route 401s by design.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# --- Postgres (Railway) ---
# Tables used today: dropship_stores, dropship_store_products, dropship_order_forwards,
# platform_settings, dropship_rate_limits. Apply infra/postgres/{002..006}*.sql once.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# --- Medusa v2 backend ---
MEDUSA_URL=https://your-medusa-backend.example.com
NEXT_PUBLIC_MEDUSA_URL=https://your-medusa-backend.example.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Option A — Medusa Admin secret API token (preferred)
MEDUSA_ADMIN_API_TOKEN=
# Option B — Medusa admin email + password
MEDUSA_ADMIN_EMAIL=
MEDUSA_ADMIN_PASSWORD=

# --- Anthropic (Claude Haiku, used by the agent) ---
ANTHROPIC_API_KEY=

# --- Suppliers ---
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
# CJ_DROPSHIPPING_API_KEY must be the API key generated under
# Account Settings → Developer, NOT the account password.
CJ_DROPSHIPPING_EMAIL=
CJ_DROPSHIPPING_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
