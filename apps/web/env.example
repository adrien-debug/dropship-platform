# =============================================================================
# Copier vers .env.local (local) ou coller dans Vercel / Railway (apps/web)
# =============================================================================

# --- Railway Postgres (base de données principale)
# Format : postgresql://user:password@host:port/db
# En production : URL publique TCP Railway (hopper.proxy.rlwy.net:51210)
# En interne Railway : postgresql://medusa:...@postgres.railway.internal:5432/medusa
DATABASE_URL=postgresql://medusa:PASS@hopper.proxy.rlwy.net:51210/medusa

# --- Medusa (backend Railway : https://medusa-production-656a.up.railway.app)
MEDUSA_URL=https://medusa-production-656a.up.railway.app
# Option A — clé secrète (Medusa Admin → Settings → Secret API Keys) recommandé
MEDUSA_ADMIN_API_TOKEN=
# Option B — compte admin Medusa
MEDUSA_ADMIN_EMAIL=admin@hearst.app
MEDUSA_ADMIN_PASSWORD=

# Affichage URL Medusa dans l'UI admin (optionnel)
NEXT_PUBLIC_MEDUSA_URL=https://medusa-production-656a.up.railway.app
